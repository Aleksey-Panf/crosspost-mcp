# Telegram Bot API
# Get token from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_channel_id_here

# Discord Webhook
# Create webhook in channel settings: Integrations -> Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Mastodon
# Create app at https://YOUR_INSTANCE/settings/applications
MASTODON_API_BASE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=your_access_token_here

# Bluesky
# Use your handle and create App Password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Reddit
# Create app at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=crosspost-mcp/0.1.0 by your_username